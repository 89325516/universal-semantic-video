{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usv-format.example/schema/defs/common.schema.json",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$"
    },
    "languageTag": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$"
    },
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "point": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "region": {
      "oneOf": [
        {
          "$ref": "#/$defs/rectRegion"
        },
        {
          "$ref": "#/$defs/quadRegion"
        },
        {
          "$ref": "#/$defs/polygonRegion"
        }
      ]
    },
    "rectRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "x", "y", "width", "height"],
      "properties": {
        "kind": {
          "const": "rect"
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "quadRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "points"],
      "properties": {
        "kind": {
          "const": "quad"
        },
        "points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/point"
          },
          "minItems": 4,
          "maxItems": 4
        }
      }
    },
    "polygonRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "points"],
      "properties": {
        "kind": {
          "const": "polygon"
        },
        "points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/point"
          },
          "minItems": 3
        }
      }
    },
    "localizedLabels": {
      "type": "object",
      "propertyNames": {
        "anyOf": [
          {
            "const": "default"
          },
          {
            "$ref": "#/$defs/languageTag"
          }
        ]
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "object_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "event_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      },
      "minProperties": 1
    }
  }
}
